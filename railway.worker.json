{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "php artisan queue:work database --sleep=3 --tries=3 --max-time=3600 --queue=default,quiz,knowledge",
    "restartPolicyType": "ALWAYS"
  }
}
