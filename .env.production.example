# === APP CORE ===
APP_NAME=Aethereum
APP_ENV=production
APP_KEY=base64:GENERATE_VIA_php_artisan_key_generate # [REQUIRED]
APP_DEBUG=false
APP_URL=YOUR_PRODUCTION_URL # [REQUIRED]

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# === DATABASE (Supabase Pooler) ===
DB_CONNECTION=pgsql
DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com # [REQUIRED]
DB_PORT=5432
DB_DATABASE=postgres # [REQUIRED]
DB_USERNAME=YOUR_SUPABASE_DB_USERNAME # [REQUIRED]
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD # [REQUIRED]
DB_SSLMODE=prefer

# === CACHE & QUEUE ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database # [REQUIRED]
CACHE_STORE=database # [REQUIRED]
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# === AWS / STORAGE ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# === EXTERNAL SERVICES ===
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=YOUR_PRODUCTION_URL/auth/google/callback

SUPABASE_URL=YOUR_SUPABASE_URL # [REQUIRED]
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY # [REQUIRED]
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET # [REQUIRED]

GEMINI_API_KEY=YOUR_GEMINI_API_KEY # [REQUIRED]
GEMINI_MODEL=gemini-2.5-flash
JINA_API_KEY=YOUR_JINA_API_KEY

FRONTEND_URL=YOUR_FRONTEND_URL # [REQUIRED]
