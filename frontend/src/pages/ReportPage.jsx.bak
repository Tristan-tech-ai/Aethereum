const demoDailyXP = (() => {
    const data = [];
    const now = new Date();
    let cumulative = 800;
    for (let i = 29; i >= 0; i--) {
        const date = new Date(now);
        date.setDate(date.getDate() - i);
        const dayXP = Math.random() > 0.15 ? Math.floor(Math.random() * 150 + 30) : 0;
        cumulative += dayXP;
        data.push({
            date: date.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
            xp: dayXP,
            cumulative,
        });
    }
    return data;
})();

