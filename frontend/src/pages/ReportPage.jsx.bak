/* ════════════════════════════════════════════════════════════
   REPORT PAGE
   ════════════════════════════════════════════════════════════ */

const ReportPage = () => {
    const { user } = useAuthStore();
    const [period, setPeriod] = useState("30d");
    const [profileData, setProfileData] = useState(null);

    useEffect(() => {
        const fetchData = async () => {
            try {
                const [profRes] = await Promise.allSettled([
                    api.get("/api/v1/profile/me"),
                    api.get("/api/v1/profile/me/xp-history"),
                ]);

                if (profRes.status === "fulfilled" && profRes.value.data?.data) {
                    setProfileData(profRes.value.data.data);
                }
            } catch (err) {
                console.error("Using fallback data for reports");
            }
        };
        fetchData();
    }, []);

    const totalCards = profileData?.stats?.total_cards ?? 27;
    const totalHours = profileData?.stats?.total_study_time_hours ?? 87;
    const totalXP = profileData?.stats?.total_xp ?? 12450;
    const avgMastery = profileData?.stats?.average_mastery ?? 89;
    const currentStreak = user?.current_streak ?? 14;
    const totalSessions = profileData?.stats?.total_sessions ?? 156;
    const avgFocus = profileData?.stats?.avg_focus ?? 91;
    const totalAchievements = profileData?.stats?.total_achievements ?? 6;

    return (
        <div className="px-4 lg:px-8 py-6 max-w-page mx-auto space-y-6">
            {/* ── Header ── */}
            <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                    <h1 className="text-h2 font-heading text-text-primary flex items-center gap-2">
                        <BarChart3 size={24} className="text-primary" />
                        Learning Report
                    </h1>
                    <p className="text-body-sm text-text-secondary mt-1">
                        Track your progress, study patterns, and knowledge growth
                    </p>
                </div>
                {/* Period Selector */}
                <div className="flex gap-1 bg-dark-secondary p-1 rounded-lg border border-border-subtle">
                    {["7d", "30d", "90d"].map((p) => (
                        <button
                            key={p}
                            onClick={() => setPeriod(p)}
                            className={`px-3 py-1.5 text-xs font-semibold rounded-md transition-all duration-fast ${
                                period === p
                                    ? "bg-primary text-white shadow-glow-primary"
                                    : "text-text-muted hover:text-text-primary"
                            }`}
                        >
                            {p === "7d" ? "7 Days" : p === "30d" ? "30 Days" : "90 Days"}
                        </button>
                    ))}
                </div>
            </div>

            {/* ── Quick Stats Grid ── */}
            <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
                <StatCard
                    icon={Zap}
                    label="Total XP"
                    value={totalXP.toLocaleString()}
                    sub="Experience Points"
                    trend="+12%"
                    trendUp
                    color="bg-primary/20"
                />
                <StatCard
                    icon={Clock}
                    label="Study Hours"
                    value={`${totalHours}h`}
                    sub={`${totalSessions} sessions`}
                    trend="+8%"
                    trendUp
                    color="bg-info/20"
                />
                <StatCard
                    icon={Flame}
                    label="Current Streak"
                    value={`${currentStreak} days`}
                    sub="Keep it up!"
                    trend="+3"
                    trendUp
                    color="bg-warning/20"
                />
                <StatCard
                    icon={Target}
                    label="Avg Mastery"
                    value={`${avgMastery}%`}
                    sub={`${totalCards} knowledge cards`}
                    trend="+5%"
                    trendUp
                    color="bg-success/20"
                />
            </div>

            {/* ── Row 2: XP Trend + Weekly Activity ── */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {/* XP Progress Chart */}
                <Card padding="spacious">
                    <div className="flex items-center justify-between mb-4">
                        <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2">
                            <TrendingUp size={16} className="text-primary" />
                            XP Progress
                        </h3>
                        <span className="text-caption text-text-muted">Last 30 days</span>
                    </div>
                    <div className="h-56">
                        <ResponsiveContainer width="100%" height="100%">
                            <AreaChart data={demoDailyXP}>
                                <defs>
                                    <linearGradient id="xpGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stopColor="#7C3AED" stopOpacity={0.3} />
                                        <stop offset="100%" stopColor="#7C3AED" stopOpacity={0} />
                                    </linearGradient>
                                </defs>
                                <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.05)" />
                                <XAxis
                                    dataKey="date"
                                    tick={{ fontSize: 10, fill: "rgba(255,255,255,0.4)" }}
                                    axisLine={false}
                                    tickLine={false}
                                    interval="preserveStartEnd"
                                />
                                <YAxis
                                    tick={{ fontSize: 10, fill: "rgba(255,255,255,0.4)" }}
                                    axisLine={false}
                                    tickLine={false}
                                    width={35}
                                />
                                <Tooltip content={<CustomTooltip />} />
                                <Area
                                    type="monotone"
                                    dataKey="xp"
                                    name="Daily XP"
                                    stroke="#7C3AED"
                                    strokeWidth={2}
                                    fill="url(#xpGradient)"
                                    dot={false}
                                    activeDot={{ r: 4, stroke: "#7C3AED", fill: "#1a0f2e", strokeWidth: 2 }}
                                />
                            </AreaChart>
                        </ResponsiveContainer>
                    </div>
                </Card>

                {/* Weekly Study Activity */}
                <Card padding="spacious">
                    <div className="flex items-center justify-between mb-4">
                        <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2">
                            <Activity size={16} className="text-info" />
                            Weekly Activity
                        </h3>
                        <span className="text-caption text-text-muted">This week</span>
                    </div>
                    <div className="h-56">
                        <ResponsiveContainer width="100%" height="100%">
                            <BarChart data={demoWeeklyActivity} barGap={4}>
                                <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.05)" />
                                <XAxis
                                    dataKey="day"
                                    tick={{ fontSize: 11, fill: "rgba(255,255,255,0.5)" }}
                                    axisLine={false}
                                    tickLine={false}
                                />
                                <YAxis
                                    tick={{ fontSize: 10, fill: "rgba(255,255,255,0.4)" }}
                                    axisLine={false}
                                    tickLine={false}
                                    width={30}
                                />
                                <Tooltip content={<CustomTooltip />} />
                                <Bar dataKey="hours" name="Hours" fill="#7C3AED" radius={[4, 4, 0, 0]} maxBarSize={28} />
                                <Bar dataKey="quizzes" name="Quizzes" fill="#3B82F6" radius={[4, 4, 0, 0]} maxBarSize={28} />
                            </BarChart>
                        </ResponsiveContainer>
                    </div>
                </Card>
            </div>

            {/* ── Row 3: Subject Breakdown + Skill Radar ── */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {/* Subject Breakdown */}
                <Card padding="spacious">
                    <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                        <PieChartIcon size={16} className="text-accent" />
                        Subject Breakdown
                    </h3>
                    <div className="flex flex-col md:flex-row items-center gap-6">
                        <div className="h-52 w-52 flex-shrink-0">
                            <ResponsiveContainer width="100%" height="100%">
                                <PieChart>
                                    <Pie
                                        data={demoSubjectBreakdown}
                                        dataKey="hours"
                                        nameKey="subject"
                                        cx="50%"
                                        cy="50%"
                                        innerRadius={45}
                                        outerRadius={75}
                                        strokeWidth={2}
                                        stroke="rgba(0,0,0,0.3)"
                                    >
                                        {demoSubjectBreakdown.map((entry, i) => (
                                            <Cell key={i} fill={entry.color} />
                                        ))}
                                    </Pie>
                                    <Tooltip content={<CustomTooltip />} />
                                </PieChart>
                            </ResponsiveContainer>
                        </div>
                        <div className="flex-1 space-y-2.5 w-full">
                            {demoSubjectBreakdown.map((s, i) => (
                                <div key={i} className="flex items-center gap-3">
                                    <span className="w-2.5 h-2.5 rounded-full flex-shrink-0" style={{ backgroundColor: s.color }} />
                                    <span className="text-body-sm text-text-secondary flex-1 truncate">{s.subject}</span>
                                    <span className="text-body-sm font-semibold text-text-primary">{s.hours}h</span>
                                    <span className="text-caption text-text-muted">{s.cards} cards</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </Card>

                {/* Skill Radar */}
                <Card padding="spacious">
                    <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                        <Brain size={16} className="text-primary-light" />
                        Skill Radar
                    </h3>
                    <div className="h-64">
                        <ResponsiveContainer width="100%" height="100%">
                            <RadarChart data={demoSkillRadar} outerRadius="70%">
                                <PolarGrid stroke="rgba(255,255,255,0.08)" />
                                <PolarAngleAxis
                                    dataKey="skill"
                                    tick={{ fontSize: 10, fill: "rgba(255,255,255,0.5)" }}
                                />
                                <PolarRadiusAxis
                                    angle={30}
                                    domain={[0, 100]}
                                    tick={{ fontSize: 9, fill: "rgba(255,255,255,0.3)" }}
                                    axisLine={false}
                                />
                                <Radar
                                    name="Score"
                                    dataKey="score"
                                    stroke="#7C3AED"
                                    fill="#7C3AED"
                                    fillOpacity={0.2}
                                    strokeWidth={2}
                                    dot={{ r: 3, fill: "#7C3AED" }}
                                />
                                <Tooltip content={<CustomTooltip />} />
                            </RadarChart>
                        </ResponsiveContainer>
                    </div>
                </Card>
            </div>

            {/* ── Row 4: Learning Heatmap ── */}
            <Card padding="spacious">
                <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                    <Calendar size={16} className="text-success" />
                    Learning Activity
                </h3>
                <LearningHeatmap weeks={52} />
            </Card>

            {/* ── Row 5: Quiz Performance + Knowledge Cards Distribution ── */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {/* Quiz Performance Trend */}
                <Card padding="spacious">
                    <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                        <Trophy size={16} className="text-warning" />
                        Quiz Performance
                    </h3>
                    <div className="h-56">
                        <ResponsiveContainer width="100%" height="100%">
                            <LineChart data={demoQuizPerformance}>
                                <CartesianGrid strokeDasharray="3 3" stroke="rgba(255,255,255,0.05)" />
                                <XAxis
                                    dataKey="month"
                                    tick={{ fontSize: 11, fill: "rgba(255,255,255,0.5)" }}
                                    axisLine={false}
                                    tickLine={false}
                                />
                                <YAxis
                                    tick={{ fontSize: 10, fill: "rgba(255,255,255,0.4)" }}
                                    axisLine={false}
                                    tickLine={false}
                                    domain={[0, 100]}
                                    width={30}
                                />
                                <Tooltip content={<CustomTooltip />} />
                                <Line
                                    type="monotone"
                                    dataKey="avgScore"
                                    name="Avg Score %"
                                    stroke="#F59E0B"
                                    strokeWidth={2.5}
                                    dot={{ r: 4, fill: "#F59E0B", stroke: "#1a0f2e", strokeWidth: 2 }}
                                    activeDot={{ r: 6, stroke: "#F59E0B", fill: "#1a0f2e", strokeWidth: 2 }}
                                />
                                <Line
                                    type="monotone"
                                    dataKey="attempts"
                                    name="Attempts"
                                    stroke="#3B82F6"
                                    strokeWidth={2}
                                    strokeDasharray="5 5"
                                    dot={{ r: 3, fill: "#3B82F6" }}
                                />
                            </LineChart>
                        </ResponsiveContainer>
                    </div>
                </Card>

                {/* Knowledge Card Tiers */}
                <Card padding="spacious">
                    <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                        <Award size={16} className="text-primary-light" />
                        Knowledge Card Tiers
                    </h3>
                    <div className="space-y-4">
                        {demoCardTiers.map((tier, i) => {
                            const totalCards = demoCardTiers.reduce((s, t) => s + t.count, 0);
                            const pct = Math.round((tier.count / totalCards) * 100);
                            return (
                                <div key={i}>
                                    <div className="flex items-center justify-between mb-1.5">
                                        <span className="text-body-sm text-text-primary font-medium flex items-center gap-2">
                                            <span>{tier.emoji}</span>
                                            {tier.tier}
                                        </span>
                                        <span className="text-caption text-text-muted">
                                            {tier.count} cards · {pct}%
                                        </span>
                                    </div>
                                    <div className="h-2.5 bg-dark-secondary rounded-full overflow-hidden">
                                        <div
                                            className="h-full rounded-full transition-all duration-500"
                                            style={{
                                                width: `${pct}%`,
                                                backgroundColor: tier.color,
                                                boxShadow: `0 0 8px ${tier.color}40`,
                                            }}
                                        />
                                    </div>
                                </div>
                            );
                        })}
                        <div className="flex items-center justify-between pt-3 border-t border-border-subtle">
                            <span className="text-body-sm text-text-secondary font-medium">Total Cards</span>
                            <span className="text-h4 font-bold text-text-primary">
                                {demoCardTiers.reduce((s, t) => s + t.count, 0)}
                            </span>
                        </div>
                    </div>
                </Card>
            </div>

            {/* ── Row 6: Additional Stats + Recent Sessions ── */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                {/* Summary Stats */}
                <Card padding="spacious">
                    <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-5">
                        <FileText size={16} className="text-info" />
                        Summary
                    </h3>
                    <div className="space-y-4">
                        {[
                            { label: "Total Sessions", value: totalSessions, icon: "📚" },
                            { label: "Avg Focus Score", value: `${avgFocus}%`, icon: "🎯" },
                            { label: "Materials Completed", value: 38, icon: "✅" },
                            { label: "Achievements Earned", value: totalAchievements, icon: "🏅" },
                            { label: "Quizzes Passed", value: 94, icon: "💯" },
                            { label: "Best Streak", value: "21 days", icon: "🔥" },
                        ].map((item, i) => (
                            <div key={i} className="flex items-center justify-between py-1">
                                <span className="text-body-sm text-text-secondary flex items-center gap-2">
                                    <span>{item.icon}</span>
                                    {item.label}
                                </span>
                                <span className="text-body-sm font-semibold text-text-primary">{item.value}</span>
                            </div>
                        ))}
                    </div>
                </Card>

                {/* Recent Study Sessions */}
                <div className="lg:col-span-2">
                    <Card padding="spacious">
                        <h3 className="text-h4 font-heading text-text-primary flex items-center gap-2 mb-4">
                            <BookOpen size={16} className="text-success" />
                            Recent Study Sessions
                        </h3>
                        <div className="space-y-1">
                            {demoRecentSessions.map((session, i) => (
                                <div
                                    key={i}
                                    className="flex items-center gap-4 py-3 px-3 rounded-lg hover:bg-white/[0.02] transition-colors"
                                >
                                    {/* Score badge */}
                                    <div className={`w-10 h-10 rounded-lg flex items-center justify-center text-xs font-bold ${
                                        session.score >= 90
                                            ? "bg-success/15 text-success"
                                            : session.score >= 80
                                                ? "bg-primary/15 text-primary-light"
                                                : "bg-warning/15 text-warning"
                                    }`}>
                                        {session.score}%
                                    </div>
                                    {/* Info */}
                                    <div className="flex-1 min-w-0">
                                        <p className="text-body-sm text-text-primary font-medium truncate">
                                            {session.title}
                                        </p>
                                        <p className="text-caption text-text-muted">
                                            {session.date} · {session.duration}
                                        </p>
                                    </div>
                                    {/* XP */}
                                    <span className="text-body-sm font-semibold text-primary-light whitespace-nowrap">
                                        +{session.xp} XP
                                    </span>
                                </div>
                            ))}
                        </div>
                    </Card>
                </div>
            </div>
        </div>
    );
};

export default ReportPage;
